# Supabase (required)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# App (required)
APP_BASE_URL=http://localhost:4000
JWT_SECRET=
PORT=4000

# Admin console (operational: withdrawals, drops, AI planner — not balance edits)
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Superadmin (balance adjust/move/set/remove and delete user only)
SUPERADMIN_USERNAME=
SUPERADMIN_PASSWORD=

# TOTP at rest (production — 64 hex chars: openssl rand -hex 32)
TOTP_ENCRYPTION_KEY=

# NOWPayments (crypto deposits + withdrawals)
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_API_BASE=https://api.nowpayments.io/v1

# Internal cron + AI planner + portal KYC review
INTERNAL_CRON_SECRET=
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat
AI_KYC_MODEL=deepseek-chat
AI_KYC_AUTO_APPROVE_THRESHOLD=0.85

# Twilio SMS (portal login OTP + alerts)
# Set TWILIO_SMS_ENABLED=0 to disable sending in dev.
TWILIO_SMS_ENABLED=1
TWILIO_ACCOUNT_SID=
TWILIO_FROM_NUMBER=
# Use EITHER auth token OR API key pair:
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=

# MT5 (MetaApi)
MT5_METAAPI_TOKEN=
# MT5_EA_WEBHOOK_SECRET=
# MT5_PRICE_FEED_SECRET=
# MT5_LIVE_SERVER=EMA-Live

# Tatum (Ethereum USDT webhooks) — optional
# TATUM_API_KEY=
# TATUM_WEBHOOK_SECRET=

# Flutterwave (Rwanda/Uganda mobile money) — optional
# FLUTTERWAVE_SECRET_HASH=
# FLUTTERWAVE_PUBLIC_KEY=

# Email (password reset, notifications) — optional
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# Shared custodial deposit addresses — optional
# CRYPTO_DEFAULT_ETH_ADDRESS=
# CRYPTO_DEFAULT_USDT_TRC20_ADDRESS=

# Dev only
# DEV_RESET_TOKEN=
